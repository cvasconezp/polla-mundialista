// Modelo de datos de la Polla Mundialista
// Base de datos: PostgreSQL (Railway)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum Stage {
  GROUP
  KNOCKOUT
}

enum Phase {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  emailVerified DateTime?
  name          String?
  image         String?
  phone         String?        // WhatsApp
  isAdmin       Boolean        @default(false)
  hasPaid       Boolean        @default(false) // legacy
  paidAmount    Float          @default(0)     // legacy
  championPick  String?        // legacy (v1)
  createdAt     DateTime       @default(now())
  predictions   Prediction[]
  phasePayments PhasePayment[]
  championPicks ChampionPick[]

  // NextAuth
  accounts Account[]
  sessions Session[]
}

model Team {
  code String @id // "ARG", "BRA", ...
  name String
  flag String // emoji o URL
  homeMatches Match[] @relation("home")
  awayMatches Match[] @relation("away")
}

model Match {
  id            Int          @id @default(autoincrement())
  externalId    Int?         @unique // id en football-data.org
  stage         Stage        @default(GROUP)
  phase         Phase?       // fase del torneo (para tablas/pagos)
  group         String?      // "A", "B", ... (solo fase de grupos)
  homeCode      String
  awayCode      String
  home          Team         @relation("home", fields: [homeCode], references: [code])
  away          Team         @relation("away", fields: [awayCode], references: [code])
  kickoff       DateTime
  status        MatchStatus  @default(SCHEDULED)
  homeScore     Int?
  awayScore     Int?
  advancingCode String?      // equipo que avanzó (solo KNOCKOUT)
  predictions   Prediction[]
  updatedAt     DateTime     @updatedAt
}

model Prediction {
  id            Int      @id @default(autoincrement())
  userId        String
  matchId       Int
  homeScore     Int
  awayScore     Int
  advancingCode String?  // para eliminatorias
  points        Int?     // cacheado tras finalizar
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, matchId])
}

// Pago por fase (cada jugador paga $5 por fase: $1 admin, $4 al bote)
model PhasePayment {
  id         Int      @id @default(autoincrement())
  userId     String
  phase      Phase
  paid       Boolean  @default(true)
  amount     Float    @default(5)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, phase])
}

// Pick de campeón por fase (para el bono escalonado 50/25/10/5/0)
model ChampionPick {
  id        Int      @id @default(autoincrement())
  userId    String
  phase     Phase
  teamCode  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, phase])
}

model Settings {
  id             Int     @id @default(1)
  tournamentName String  @default("Polla Mundialista 2026")
  currency       String  @default("USD")
  entryFee       Float   @default(5)
  adminFee       Float   @default(1)
  phaseShare     Float   @default(0.6)
  generalShare   Float   @default(0.4)
  ptsExact       Int     @default(5)
  ptsDiff        Int     @default(3)
  ptsWinner      Int     @default(1)
  ptsAdvance     Int     @default(2)
  ptsChampion    Int     @default(10)
  championWinner String? // código del campeón real cuando termine el torneo
}

// ---- NextAuth (Auth.js) ----
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
